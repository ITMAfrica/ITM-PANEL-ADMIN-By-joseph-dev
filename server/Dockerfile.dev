# ============================================
# Dockerfile dev — API Express avec hot reload
# ============================================
FROM node:22-slim

WORKDIR /app

# Installer OpenSSL (requis par Prisma pour PostgreSQL)
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# Install Bun pour utiliser bun.lock
RUN npm install -g bun

# Copier les fichiers de dépendances racine
COPY package.json bun.lock ./

# Installer les dépendances
RUN bun install --no-frozen-lockfile

# Générer le client Prisma
COPY prisma ./prisma
RUN npx prisma generate

# Exposer le port
EXPOSE 3001

# Lancer avec tsx watch (hot reload)
CMD ["npx", "tsx", "watch", "server/index.ts"]
