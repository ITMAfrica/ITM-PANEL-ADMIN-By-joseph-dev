# ============================================
# Dockerfile dev — API Express avec hot reload
# ============================================
FROM node:22-slim

WORKDIR /app

# Installer OpenSSL (requis par Prisma pour PostgreSQL)
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# Copier les fichiers de dépendances racine
COPY package.json package-lock.json ./

# Installer les dépendances (npm, lockfile unique)
RUN npm install --legacy-peer-deps

# Générer le client Prisma
COPY prisma ./prisma
RUN npx prisma generate

# Exposer le port
EXPOSE 3001

# Appliquer les migrations, regénérer le client Prisma, puis lancer avec tsx watch (hot reload)
CMD ["sh", "-c", "npx prisma migrate deploy && npx prisma generate && npx tsx watch server/index.ts"]
