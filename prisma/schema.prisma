generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  tenant_admin
  editor
  contributor
  reader
  member
}

enum UserStatus {
  online
  away
  offline
  busy
}

enum ContentStatus {
  draft
  review
  approved
  scheduled
  published
  archived
}

enum ContentPriority {
  low
  medium
  high
  urgent
}

enum ContentType {
  newsletter
  article
  announcement
  communique
  campaign
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  avatar       String?
  passwordHash String     @default("")
  role         UserRole   @default(contributor)
  status       UserStatus @default(offline)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedTasks      Task[]            @relation("AssignedTo")
  createdTasks       Task[]            @relation("CreatedBy")
  comments           Comment[]
  uploadedFiles      FileItem[]
  workspaceMembers   WorkspaceMember[]
  teamMembers        TeamMember[]
  wikiEdits          WikiPage[]
  meetingMemberships MeetingMember[]
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#10b981")
  icon        String   @default("🏢")
  type        String   @default("brand")
  country     String   @default("France")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members              WorkspaceMember[]
  projects             Project[]
  teams                Team[]
  automations          Automation[]
  files                FileItem[]
  wikiPages            WikiPage[]
  activityLogs         ActivityLog[]
  campaigns            Campaign[]
  mediaItems           MediaItem[]
  distributionChannels DistributionChannel[]
  contentTemplates     ContentTemplate[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  icon        String   @default("📋")
  status      String   @default("active")
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]
  meetings  Meeting[]

  @@index([workspaceId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  tags        String    @default("")
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  creatorId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?     @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User?     @relation("CreatedBy", fields: [creatorId], references: [id], onDelete: SetNull)
  subtasks Subtask[]
  comments Comment[]

  @@index([projectId])
  @@index([assigneeId])
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)
  taskId    String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  duration    Int      @default(60)
  status      String   @default("scheduled")
  link        String?
  projectId   String?
  createdAt   DateTime @default(now())

  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  meetingMembers MeetingMember[]

  @@index([projectId])
}

model MeetingMember {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  workspaceId String
  createdAt   DateTime @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamMembers TeamMember[]

  @@index([workspaceId])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Automation {
  id          String    @id @default(cuid())
  name        String
  trigger     String
  action      String
  enabled     Boolean   @default(true)
  lastRun     DateTime?
  runCount    Int       @default(0)
  workspaceId String
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FileItem {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("other")
  size        Int      @default(0)
  url         String
  projectId   String?
  workspaceId String
  uploadedBy  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model WikiPage {
  id           String   @id @default(cuid())
  title        String
  content      String   @default("")
  icon         String   @default("📄")
  parentId     String?
  workspaceId  String
  lastEditedBy String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  editor    User?     @relation(fields: [lastEditedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String
  userId      String
  description String
  targetId    String?
  targetType  String?
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

model Site {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  url        String    @default("")
  apiKey     String    @unique @default(cuid())
  status     String    @default("pending")
  tenantId   String
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  contents Content[]

  @@index([tenantId])
  @@index([status])
}

model Content {
  id          String          @id
  type        ContentType
  status      ContentStatus   @default(draft)
  title       String
  excerpt     String          @default("")
  body        String          @default("")
  tenantId    String
  siteId      String
  authorId    String?
  priority    ContentPriority @default(medium)
  tags        Json            @default("[]")
  metadata    Json            @default("{}")
  viewCount   Int             @default(0)
  clickCount  Int             @default(0)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  site   Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  events ContentEvent[]

  @@index([siteId])
  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([scheduledAt])
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  color          String   @default("#3b82f6")
  status         String   @default("draft")
  startDate      DateTime
  endDate        DateTime
  tenantId       String
  contentCount   Int      @default(0)
  publishedCount Int      @default(0)
  totalReach     Int      @default(0)
  avgOpenRate    Float    @default(0)
  avgClickRate   Float    @default(0)
  channels       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model MediaItem {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("other")
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  url          String
  thumbnailUrl String?
  uploadedBy   String?
  tenantId     String
  alt          String?
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model DistributionChannel {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("email")
  icon            String    @default("mail")
  subscriberCount Int       @default(0)
  isActive        Boolean   @default(true)
  tenantId        String
  lastSentAt      DateTime?
  createdAt       DateTime  @default(now())

  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ContentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  type        String   @default("article")
  thumbnail   String   @default("")
  category    String   @default("general")
  isPremium   Boolean  @default(false)
  usageCount  Int      @default(0)
  tenantId    String?
  body        String   @default("")
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
}

model ContentEvent {
  id        String   @id @default(cuid())
  contentId String
  siteSlug  String
  eventType String
  linkUrl   String?
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([eventType])
  @@index([createdAt])
}
