generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  tenant_admin
  editor
  contributor
  reader
  member
}

enum UserStatus {
  online
  away
  offline
  busy
}

enum ContentStatus {
  draft
  review
  approved
  scheduled
  published
  archived
}

enum ContentPriority {
  low
  medium
  high
  urgent
}

enum ContentType {
  newsletter
  article
  announcement
  communique
  campaign
  social
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  avatar       String?
  passwordHash String     @default("")
  role         UserRole   @default(contributor)
  status       UserStatus @default(offline)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedTasks      Task[]            @relation("AssignedTo")
  createdTasks       Task[]            @relation("CreatedBy")
  comments           Comment[]
  uploadedFiles      FileItem[]
  workspaceMembers   WorkspaceMember[]
  teamMembers        TeamMember[]
  wikiEdits          WikiPage[]
  meetingMemberships MeetingMember[]
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#10b981")
  icon        String   @default("🏢")
  type        String   @default("brand")
  country     String   @default("France")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members              WorkspaceMember[]
  projects             Project[]
  teams                Team[]
  automations          Automation[]
  files                FileItem[]
  wikiPages            WikiPage[]
  activityLogs         ActivityLog[]
  campaigns            Campaign[]
  mediaItems           MediaItem[]
  distributionChannels DistributionChannel[]
  socialConnections    SocialConnection[]
  socialConversations  SocialConversation[]
  widgetTokens          WidgetToken[]
  contentTemplates     ContentTemplate[]
  newsletterTemplates  NewsletterTemplate[]
  contentChannels      ContentChannel[]
  subscriptionSources  SubscriptionSource[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        UserRole @default(member)
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  icon        String   @default("📋")
  status      String   @default("active")
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]
  meetings  Meeting[]

  @@index([workspaceId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  tags        String    @default("")
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  creatorId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?     @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User?     @relation("CreatedBy", fields: [creatorId], references: [id], onDelete: SetNull)
  subtasks Subtask[]
  comments Comment[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([creatorId])
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)
  taskId    String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  duration    Int      @default(60)
  status      String   @default("scheduled")
  link        String?
  projectId   String?
  createdAt   DateTime @default(now())

  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  meetingMembers MeetingMember[]

  @@index([projectId])
}

model MeetingMember {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  workspaceId String
  createdAt   DateTime @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamMembers TeamMember[]

  @@index([workspaceId])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Automation {
  id          String    @id @default(cuid())
  name        String
  trigger     String
  action      String
  enabled     Boolean   @default(true)
  lastRun     DateTime?
  runCount    Int       @default(0)
  workspaceId String
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FileItem {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("other")
  size        Int      @default(0)
  url         String
  projectId   String?
  workspaceId String
  uploadedBy  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model WikiPage {
  id           String   @id @default(cuid())
  title        String
  content      String   @default("")
  icon         String   @default("📄")
  parentId     String?
  workspaceId  String
  lastEditedBy String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  editor    User?     @relation(fields: [lastEditedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([parentId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String
  userId      String
  description String
  targetId    String?
  targetType  String?
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

model Site {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  url        String    @default("")
  apiKey     String    @unique @default(cuid())
  status     String    @default("pending")
  tenantId   String
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  contents            Content[]
  subscriptionSources SubscriptionSource[]

  @@index([tenantId])
  @@index([status])
}

model Content {
  id          String          @id
  type        ContentType
  status      ContentStatus   @default(draft)
  title       String
  body        String          @default("")
  tenantId    String
  siteId      String
  authorId    String?
  priority    ContentPriority @default(medium)
  tags        Json            @default("[]")
  metadata    Json            @default("{}")
  viewCount   Int             @default(0)
  clickCount  Int             @default(0)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  site         Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  events       ContentEvent[]
  sends        NewsletterSend[]
  channelLinks ContentChannel[]
  socialConversations SocialConversation[]

  @@index([siteId])
  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([scheduledAt])
}

model ContentChannel {
  id        String   @id @default(cuid())
  contentId String
  channelId String
  tenantId  String
  createdAt DateTime @default(now())

  content Content             @relation(fields: [contentId], references: [id], onDelete: Cascade)
  channel DistributionChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tenant  Workspace           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([contentId, channelId])
  @@index([contentId])
  @@index([channelId])
  @@index([tenantId])
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  color          String   @default("#3b82f6")
  status         String   @default("draft")
  startDate      DateTime
  endDate        DateTime
  tenantId       String
  contentCount   Int      @default(0)
  publishedCount Int      @default(0)
  totalReach     Int      @default(0)
  avgOpenRate    Float    @default(0)
  avgClickRate   Float    @default(0)
  channels       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model MediaItem {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("other")
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  url          String
  thumbnailUrl String?
  uploadedBy   String?
  tenantId     String
  alt          String?
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([uploadedBy])
}

model DistributionChannel {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("email")
  icon            String    @default("mail")
  subscriberCount Int       @default(0)
  isActive        Boolean   @default(true)
  tenantId        String
  lastSentAt      DateTime?
  // Canal social : connexion externe (Page Facebook…) portant le token.
  // Null pour les canaux classiques (email, web…). SetNull si la connexion est supprimée.
  socialConnectionId String?
  createdAt       DateTime  @default(now())

  workspace        Workspace            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  socialConnection SocialConnection?    @relation(fields: [socialConnectionId], references: [id], onDelete: SetNull)
  sources          SubscriptionSource[]
  subscriptions    Subscription[]
  contentChannels  ContentChannel[]
  widgetTokens     WidgetToken[]

  @@index([tenantId])
  @@index([socialConnectionId])
}

// Connexion OAuth à une plateforme sociale (v1 : Page Facebook uniquement).
// Porte les secrets (chiffrés AES-256-GCM côté applicatif) — ne JAMAIS exposer
// pageAccessToken dans une réponse API. Le canal associé (DistributionChannel)
// n'est qu'un pointeur affichable dans l'UI.
model SocialConnection {
  id              String    @id @default(cuid())
  tenantId        String
  platform        String    @default("facebook")
  pageId          String
  pageName        String
  // Token chiffré au format versionné "v1:iv:tag:ciphertext" (server/lib/crypto.ts).
  pageAccessToken String
  tokenExpiresAt  DateTime?
  scopes          Json      @default("[]")
  status          String    @default("connected") // connected | expired | revoked | error
  connectedBy     String?
  lastPublishAt   DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channels  DistributionChannel[]
  conversations SocialConversation[]

  // Dernière synchro des commentaires (inbox) — throttle du polling.
  lastInboxSyncAt DateTime?

  @@unique([tenantId, platform, pageId])
  @@index([tenantId])
}

// Boîte de réception sociale : un fil = un commentaire racine sur un post
// publié (v1 : Facebook). Modèle volontairement générique (platform,
// externalThreadId) pour absorber Instagram/TikTok sans migration.
model SocialConversation {
  id               String   @id @default(cuid())
  tenantId         String
  connectionId     String
  platform         String   @default("facebook")
  // Id du commentaire racine sur la plateforme (= le fil).
  externalThreadId String
  externalPostId   String
  // Notre Content si le post vient du panel (null = post externe).
  contentId        String?
  authorName       String
  authorExternalId String?
  preview          String   @default("")
  status           String   @default("unresolved") // unresolved | resolved
  unread           Boolean  @default(true)
  lastMessageAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace  Workspace        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  content    Content?         @relation(fields: [contentId], references: [id], onDelete: SetNull)
  messages   SocialMessage[]

  @@unique([connectionId, externalThreadId])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, platform])
  @@index([connectionId])
}

model SocialMessage {
  id               String   @id @default(cuid())
  conversationId   String
  // Id du commentaire sur la plateforme (dédoublonnage via l'unique ci-dessous).
  externalId       String
  direction        String // inbound (utilisateur) | outbound (notre Page)
  authorName       String
  authorExternalId String?
  body             String
  publishedAt      DateTime
  createdAt        DateTime @default(now())

  conversation SocialConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, externalId])
  @@index([conversationId, publishedAt])
}

model Subscriber {
  id               String           @id @default(cuid())
  email            String
  name             String?
  tenantId         String
  status           SubscriberStatus @default(subscribed)
  unsubscribeToken String           @unique @default(cuid())
  createdAt        DateTime         @default(now())

  subscriptions Subscription[]
  sends         NewsletterSend[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum SubscriberStatus {
  subscribed
  unsubscribed
}

model SubscriptionSource {
  id          String   @id @default(cuid())
  tenantId    String
  siteId      String?
  channelId   String
  formKey     String   @default("default")
  type        String   @default("site")
  consentedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  channel       DistributionChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  site          Site?               @relation(fields: [siteId], references: [id], onDelete: SetNull)
  tenant        Workspace           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([channelId, formKey])
  @@index([tenantId])
  @@index([channelId])
  @@index([siteId])
}

model Subscription {
  id                   String           @id @default(cuid())
  subscriberId         String
  sourceId             String
  channelId            String
  status               SubscriberStatus @default(subscribed)
  consentedAt          DateTime         @default(now())
  consentNewsletter    Boolean          @default(false)
  consentPrivacy       Boolean          @default(false)
  consentTextVersion   String?
  ipAddress            String?
  city                 String?
  country              String?
  metadata             Json             @default("{}")
  createdAt            DateTime         @default(now())

  subscriber Subscriber          @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  source     SubscriptionSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  channel    DistributionChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, channelId])
  @@index([subscriberId])
  @@index([sourceId])
  @@index([channelId])
  @@index([country])
}

model NewsletterSend {
  id           String     @id @default(cuid())
  contentId    String
  subscriberId String
  channelId    String
  status       SendStatus @default(sent)
  openedAt     DateTime?
  clickedAt    DateTime?
  ipAddress    String?
  city         String?
  country      String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  content    Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([subscriberId])
  @@index([channelId])
  @@index([status])
}

enum SendStatus {
  sent
  delivered
  opened
  clicked
  bounced
}

model ContentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  type        String   @default("article")
  thumbnail   String   @default("")
  category    String   @default("general")
  isPremium   Boolean  @default(false)
  usageCount  Int      @default(0)
  tenantId    String?
  body        String   @default("")
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
}

model NewsletterTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  subject     String   @default("")
  preheader   String   @default("")
  thumbnail   String   @default("")
  category    String   @default("general")
  isPremium   Boolean  @default(false)
  usageCount  Int      @default(0)
  tenantId    String?
  body        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([category])
}

model ContentEvent {
  id        String   @id @default(cuid())
  contentId String
  siteSlug  String
  eventType String
  linkUrl   String?
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([eventType])
  @@index([createdAt])
}

model WidgetToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  channelId String
  tenantId  String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  channel DistributionChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tenant  Workspace           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([channelId])
  @@index([tenantId])
}
