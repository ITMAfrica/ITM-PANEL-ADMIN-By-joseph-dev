# ============================================
# ITM Panel Admin — Variables d'environnement
# Copier vers .env et adapter les valeurs
# ============================================

# Postgres tourne dans Docker (port 5432 exposé). Prisma : bash scripts/db.sh <commande>
DATABASE_URL="postgresql://itm:itm_password@localhost:5432/itm_panel"

# Clé secrète JWT (obligatoire en production — min. 32 caractères aléatoires)
AUTH_SECRET="change-me-in-production-use-a-strong-random-string"

# Clé API publique (obligatoire pour /api/track et activation de sites)
PUBLIC_API_KEY="change-me-in-production"

# Inscription publique : "true" | "false" (défaut : autorisée en dev, bloquée en production)
ALLOW_PUBLIC_REGISTER="true"

NEXT_PUBLIC_APP_URL="http://localhost:3002"
APP_URL="http://localhost:3002"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

NODE_ENV="development"
PORT=3001
HOST=0.0.0.0

# Email provider pour l'envoi de newsletters.
# "console" (défaut) : loggue les envois sans réseau (dev/test).
# "smtp" : envoie via un vrai serveur SMTP (ex. Hostinger).
# "itm-send-email" : utilise l'API ITM Send Email (http://localhost:5001).
EMAIL_PROVIDER="console"
EMAIL_FROM="newsletter@itm.example"

# Configuration SMTP (utilisée quand EMAIL_PROVIDER=smtp).
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="joseph.ny@basafrica.com"
SMTP_PASS="change-me"





# URL de l'API ITM Send Email (utilisée quand EMAIL_PROVIDER=itm-send-email).
ITM_SEND_EMAIL_URL="http://localhost:5001"

# Stockage des médias uploadés (Azure Blob Storage, accès public via CDN).
# Au moins une des deux configs ci-dessous est requise (le serveur refuse de démarrer sinon).
# AZURE_STORAGE_CONNECTION_STRING (privilégié) fourni dans le portail Azure > Clé d'accès.
AZURE_STORAGE_CONNECTION_STRING=""
# Alternative : compte + clé (Clé d'accès > key1/key2).
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_ACCESS_KEY=""
# Nom du container (créé automatiquement en accès "blob" public si absent).
AZURE_STORAGE_CONTAINER="media"
# Optionnel : URL CDN custom (ex. https://cdn.tondomaine.com). Sinon l'URL Azure est utilisée.
AZURE_STORAGE_CDN_URL=""
# Taille max d'un upload (Mo).
MAX_UPLOAD_SIZE_MB=10
